# ─── Database (Neon) ──────────────────────────────────────
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# ─── Neon Auth ────────────────────────────────────────────
NEON_AUTH_BASE_URL=https://<neon-auth-host>/auth
NEON_AUTH_COOKIE_SECRET=<32-byte-base64-secret>

# ─── Stripe: which mode is active ─────────────────────────
# "test" in development, "live" in production.
# Flipping this single value switches every Stripe call + webhook.
STRIPE_MODE=test

# ─── Stripe: test-mode keys (chanmeng.org test data) ──────
# From https://dashboard.stripe.com/test/apikeys (logged into chanmeng.org)
STRIPE_TEST_SECRET_KEY=sk_test_...
# From `stripe listen --forward-to http://localhost:3000/api/stripe/webhook`
STRIPE_TEST_WEBHOOK_SECRET=whsec_...
# Publishable key (not currently used in code; safe to leave blank for now)
NEXT_PUBLIC_STRIPE_TEST_PUBLISHABLE_KEY=pk_test_...

# ─── Stripe: live-mode keys (chanmeng.org real money) ─────
# From https://dashboard.stripe.com/apikeys (chanmeng.org, live toggle on)
STRIPE_LIVE_SECRET_KEY=sk_live_...
# From the production webhook endpoint config in the Stripe dashboard
STRIPE_LIVE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_LIVE_PUBLISHABLE_KEY=pk_live_...

# ─── Cloudinary ───────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
